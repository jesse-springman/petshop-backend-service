generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Business{
  id String @id @default(uuid())
  name String
  plan Plan
  commerce Commerce
  status Status @default(PENDING)
 active Boolean @default(true)
 createdAt DateTime @default(now())

 customers Customer[]
  users User[]
  appointments Appointment[]
  pets Pet[]
  vehicles Vehicle[]
}


model Customer {
  id              String        @id @default(uuid())
  name   String
  phone  String?
  address         String?
  created_at      DateTime      @default(now())
  businessId       String
  business         Business @relation(fields: [businessId], references: [id])

  pets Pet[]
  vehicles Vehicle[]
  appointments    Appointment[]
}


model Pet {
  id String @id @default(uuid())
  name String
  breed String?
  lastBath     DateTime?
  create_at DateTime @default(now())
  customerId String
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  businessId String
  business Business @relation(fields: [businessId], references: [id])

  appointments Appointment[]
}

model Vehicle {
  id String @id @default(uuid())
  brand String
  model String
  plate String?
  create_at DateTime @default(now())
  customerId String
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  businessId String
  business Business @relation(fields: [businessId], references: [id])

  appointments Appointment[]
}


model User {
  id           String        @id @default(uuid())
  name         String        @unique
  password     String
  role         Role
  created_at   DateTime      @default(now())
  businessId String
  business Business @relation(fields: [businessId], references: [id])

  appointments Appointment[]
}

model Appointment {
  id         String            @id @default(uuid())
  date       DateTime
  status     AppointmentStatus @default(SCHEDULED)
  notes      String?
  created_at DateTime          @default(now())
  businessId String
  business Business @relation(fields: [businessId], references: [id])
  customerId String
  customer   Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  petId String?
  pet Pet? @relation(fields: [petId], references: [id])
  vehicleId String?
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])



  @@unique([date, userId])
  @@index([date])
  @@index([customerId])
}

enum Commerce {
  PETSHOP
  AUTOMOTIVE
  FEMININE_AESTHETIC
}

enum Status {
  ACTIVE
  PENDING
  SUSPENDED
  CANCELED
}

enum Plan {
  BASIC
  GOLD
}

enum Role {
  ADMIN
  USER
  SUPERADMIN
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}
