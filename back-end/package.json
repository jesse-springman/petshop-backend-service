{
  "name": "customers-pet",
  "version": "0.0.1",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "npm run docker:up && npm run start:dev",
    "build": "prisma generate && prisma migrate deploy && nest build",
    "docker:up": "docker compose -f ../infra/compose.yaml up -d",
    "docker:down": "docker compose -f ../infra/compose.yaml down",
    "docker:stop": "docker compose -f ../infra/compose.yaml stop",
    "migrate:prod": "dotenv -e .env.production -- prisma migrate deploy",
    "migrate:dev": "dotenv -e .env -- prisma migrate dev",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "setupTest:e2e": "npm run generate: test && npm run migrate:test",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:test:push": "dotenv -e .env.test -- prisma db push",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "vercel-build": "npx prisma generate && npx prisma migrate deploy && npm run build",
    "create:admin": "dotenv -e .env.production -- ts-node scripts/create-admin.ts"
  },
  "dependencies": {
    "@nestjs/config": "^4.0.2",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/client": "^5.14.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/common": "^11.1.11",
    "@nestjs/core": "^11.1.11",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.11",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "29.5.14",
    "@types/node": "^22.19.3",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.2.0",
    "prettier": "^3.4.2",
    "prisma": "^5.14.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript-eslint": "^8.20.0"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  },
  "main": "index.js",
  "keywords": [],
  "description": ""
}
